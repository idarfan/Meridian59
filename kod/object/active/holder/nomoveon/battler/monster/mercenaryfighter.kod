%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Combat-only variant of Mercenary -- follows and fights, never heals.
% Meant to be paired with a MercenaryHealer bound to the same master.
MercenaryFighter is Mercenary

constants:

   include blakston.khd

resources:

   mercfighter_name_rsc = "mercenary (fighter)"

classvars:

   vrName = mercfighter_name_rsc

   vbCanFight = TRUE
   vbCanHeal = FALSE

properties:

messages:

end
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
